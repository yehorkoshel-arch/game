[
  {
    "id": "robot_intro_01",
    "group": "robot_intro",
    "text": "Привіт! Я Роботрон-9000."
  },
  {
    "id": "robot_intro_02",
    "group": "robot_intro",
    "text": "Хочу розповісти тобі одну важливу історію..."
  },
  {
    "id": "robot_intro_03",
    "group": "robot_intro",
    "text": "Жив собі хлопець на ім'я Андрій."
  },
  {
    "id": "robot_intro_04",
    "group": "robot_intro",
    "text": "Звичайний київський школяр, добрий і веселий."
  },
  {
    "id": "robot_intro_05",
    "group": "robot_intro",
    "text": "Кожного ранку він біг на уроки вулицями міста."
  },
  {
    "id": "robot_intro_06",
    "group": "robot_intro",
    "text": "Але сьогодні щось пішло не так..."
  },
  {
    "id": "robot_intro_07",
    "group": "robot_intro",
    "text": "Охоронці вирішили його зупинити!"
  },
  {
    "id": "robot_intro_08",
    "group": "robot_intro",
    "text": "Андрій не злякався."
  },
  {
    "id": "robot_intro_09",
    "group": "robot_intro",
    "text": "Він побіг, швидко, спритно, хоробро!"
  },
  {
    "id": "robot_intro_10",
    "group": "robot_intro",
    "text": "Допоможи йому добігти до фінішу."
  },
  {
    "id": "robot_intro_11",
    "group": "robot_intro",
    "text": "Слава Україні! 🇺🇦"
  },
  {
    "id": "andrii_start_01",
    "group": "andrii_start",
    "text": "Ну що ж, побігли!"
  },
  {
    "id": "andrii_start_02",
    "group": "andrii_start",
    "text": "Поїхали! Тримайтесь!"
  },
  {
    "id": "andrii_start_03",
    "group": "andrii_start",
    "text": "Вперед, нікого не боюся!"
  },
  {
    "id": "andrii_cop_01",
    "group": "andrii_cop",
    "text": "О, охоронець! Не дожене!"
  },
  {
    "id": "andrii_cop_02",
    "group": "andrii_cop",
    "text": "Ану, спробуй мене зупини!"
  },
  {
    "id": "andrii_cop_03",
    "group": "andrii_cop",
    "text": "Я швидший за тебе!"
  },
  {
    "id": "andrii_cop_04",
    "group": "andrii_cop",
    "text": "Біжи-біжи, не доженеш!"
  },
  {
    "id": "andrii_tck_01",
    "group": "andrii_tck",
    "text": "ТЦК?! Та я вас не боюся!"
  },
  {
    "id": "andrii_tck_02",
    "group": "andrii_tck",
    "text": "Повістку? Ні дякую, побіжу!"
  },
  {
    "id": "andrii_tck_03",
    "group": "andrii_tck",
    "text": "Не сьогодні, хлопці!"
  },
  {
    "id": "andrii_tck_04",
    "group": "andrii_tck",
    "text": "Я ще встигну на урок!"
  },
  {
    "id": "andrii_hit_01",
    "group": "andrii_hit",
    "text": "Ой! Але я не здаюсь!"
  },
  {
    "id": "andrii_hit_02",
    "group": "andrii_hit",
    "text": "Все одно добіжу!"
  },
  {
    "id": "andrii_hit_03",
    "group": "andrii_hit",
    "text": "Це ще не кінець!"
  },
  {
    "id": "andrii_lose_01",
    "group": "andrii_lose",
    "text": "Ай, боляче! Але я повернусь!"
  },
  {
    "id": "andrii_lose_02",
    "group": "andrii_lose",
    "text": "Ой боляче... Дайте відпочити!"
  },
  {
    "id": "andrii_lose_03",
    "group": "andrii_lose",
    "text": "Ай! Цього разу не вийшло..."
  },
  {
    "id": "andrii_win_01",
    "group": "andrii_win",
    "text": "УРА! ПЕРЕМОГА! Я зробив це!"
  },
  {
    "id": "andrii_win_02",
    "group": "andrii_win",
    "text": "Ура! Дійшов до фінішу! Слава Україні!"
  },
  {
    "id": "andrii_win_03",
    "group": "andrii_win",
    "text": "ПЕРЕМОГА! Ніхто мене не зупинить!"
  },
  {
    "id": "story_tck_01",
    "group": "story_tck",
    "speaker": "Андрій",
    "text": "От лишенько, чорна машина... Вони вже близько. Що робити?"
  },
  {
    "id": "story_tck_02",
    "group": "story_tck",
    "speaker": "ТЦК",
    "text": "Підпиши документи, хлопче."
  },
  {
    "id": "story_tck_03",
    "group": "story_tck",
    "speaker": "Андрій",
    "text": "Я не буду підписувати ваші документи."
  },
  {
    "id": "story_tck_04",
    "group": "story_tck",
    "speaker": "ТЦК",
    "text": "А ну, ти, хлопче, зараз підеш до нас. Іди сюди."
  },
  {
    "id": "story_tck_05",
    "group": "story_tck",
    "speaker": "Андрій",
    "text": "Ні. Я маю добігти до фінішу."
  },
  {
    "id": "story_tck_06",
    "group": "story_tck",
    "speaker": "ТЦК",
    "text": "Не сперечайся, хлопче. Ми все одно наздоженемо."
  },
  {
    "id": "story_tck_07",
    "group": "story_tck",
    "speaker": "Андрій",
    "text": "Спробуйте наздогнати. Я не здаюся."
  },
  {
    "id": "story_tck_08",
    "group": "story_tck",
    "speaker": "ТЦК",
    "text": "Тримайте його."
  },
  {
    "id": "story_tck_09",
    "group": "story_tck",
    "speaker": "Андрій",
    "text": "Роботроне, допоможи. Я побіг."
  },
  {
    "id": "march_vocal_01",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Шалійте шалійте скажені кати"
  },
  {
    "id": "march_vocal_02",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Годуйте шпіонів будуйте тюрми"
  },
  {
    "id": "march_vocal_03",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "До бою сто тисяч поборників стане"
  },
  {
    "id": "march_vocal_04",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Пірвем пірвем пірвем ті кайдани"
  },
  {
    "id": "march_vocal_05",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "За правду за волю ми станемо враз"
  },
  {
    "id": "march_vocal_06",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Ланці ні багнети не пострах для нас"
  },
  {
    "id": "march_vocal_07",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Бо вольного духа не скути в кайдани"
  },
  {
    "id": "march_vocal_08",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Біда біда біда вам тирани"
  },
  {
    "id": "march_vocal_09",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Робітники духа Робітникам всім"
  },
  {
    "id": "march_vocal_10",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Ми руки подаймо на бій їх ведім"
  },
  {
    "id": "march_vocal_11",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Бо спільна усіх нас злучила недоля"
  },
  {
    "id": "march_vocal_12",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "І труд і піт і кров кнут неволя"
  },
  {
    "id": "march_vocal_13",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Від краю до краю не громи гудуть"
  },
  {
    "id": "march_vocal_14",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Українські полки на ворога йдуть"
  },
  {
    "id": "march_vocal_15",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "І поклик рокоче Вставайте народи"
  },
  {
    "id": "march_vocal_16",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Прийшла пора пора день свободи"
  },
  {
    "id": "march_vocal_17",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Підвалини світу валяться старі"
  },
  {
    "id": "march_vocal_18",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Поблідли деспоти дрожать опирі"
  },
  {
    "id": "march_vocal_19",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Бо зоря свободи вже сходить яскрава"
  },
  {
    "id": "march_vocal_20",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Для всіх для всіх для всіх рівні права"
  },
  {
    "id": "march_vocal_21",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "І вольні народи як добрі брати"
  },
  {
    "id": "march_vocal_22",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Полинуть до сонця до щастя мети"
  },
  {
    "id": "march_vocal_23",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Розкуєсь двигнеться і наша родина"
  },
  {
    "id": "march_vocal_24",
    "group": "march_vocal",
    "speaker": "Хор",
    "text": "Одна сильна вільна Україна"
  }
]
